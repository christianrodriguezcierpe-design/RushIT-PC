# Browser app env
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service-script env
# SUPABASE_URL may match VITE_SUPABASE_URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Postmark notification provider env
# Only required when the deployment enables notifications with Postmark.
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
POSTMARK_FROM_NAME=

# SMTP notification provider env
# RushIT-PC uses SMTP as the default provider path when notifications are enabled for validation.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_SECURE=